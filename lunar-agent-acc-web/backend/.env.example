# MongoDB connection (use admin DB in URI for auth; we use database below for data)
MONGO_URI=mongodb://user:password@host:port/admin?serverSelectionTimeoutMS=7000&connectTimeoutMS=30000&maxIdleTimeMS=600000
DB_NAME=lnsms

# Server port
PORT=58001

# Listen address (default 0.0.0.0 = all interfaces, external access)
# HOST=127.0.0.1
